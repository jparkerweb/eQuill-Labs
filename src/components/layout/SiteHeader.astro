---
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  { href: '/about/', label: 'About' },
];

function isCurrent(href: string) {
  if (href === '/') return path === '/' || path === '';
  return path === href || path.startsWith(href);
}
---

<a href="#main" class="skip-link">Skip to content</a>

<header class="site-header">
  <div class="shell">
    <div class="brand">
      <a href="/" class="brand-link" aria-label="eQuill Labs home">
        <img
          src="/brand/logo-text-outline.png"
          alt="eQuill Labs"
          class="brand-logo"
          width="533"
          height="85"
        />
      </a>
    </div>
    <nav aria-label="Primary" class="primary-nav" data-open="false">
      <button
        type="button"
        class="nav-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="primary-menu">
        <span class="nav-toggle-bars" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
      <ul id="primary-menu" role="list">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isCurrent(item.href) ? 'page' : undefined}
                class:list={['nav-link', { 'is-current': isCurrent(item.href) }]}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 8px;
    background: rgb(var(--surface-1));
    color: rgb(var(--text-1));
    padding: 10px 16px;
    border-radius: 8px;
    border: 1px solid rgb(var(--accent));
    z-index: 100;
  }
  .skip-link:focus {
    left: 8px;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgb(var(--bg) / 0.8);
    border-bottom: 1px solid rgb(var(--border));
  }

  .shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-link {
    text-decoration: none;
    color: rgb(var(--text-1));
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    padding: 0 4px;
    border-radius: 6px;
  }
  .brand-link:focus-visible {
    outline: 2px solid rgb(var(--focus-ring));
    outline-offset: 2px;
  }
  .brand-logo {
    display: block;
    height: 36px;
    width: auto;
  }

  .primary-nav {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .primary-nav ul {
    display: flex;
    gap: 4px;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: 0 12px;
    text-decoration: none;
    color: rgb(var(--text-2));
    font-size: 15px;
    font-weight: 500;
    border-radius: 8px;
    transition:
      color 150ms ease,
      background 150ms ease;
  }
  .nav-link:hover {
    color: rgb(var(--text-1));
    background: rgb(var(--surface-1));
  }
  .nav-link.is-current {
    color: rgb(var(--text-1));
    position: relative;
  }
  .nav-link.is-current::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 6px;
    height: 2px;
    border-radius: 2px;
    background-image: linear-gradient(
      90deg,
      rgb(var(--grad-1)),
      rgb(var(--grad-2)),
      rgb(var(--grad-3))
    );
  }
  .nav-link:focus-visible {
    outline: 2px solid rgb(var(--focus-ring));
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .shell {
      padding: 10px 12px;
      gap: 8px;
    }
    .nav-link {
      padding: 0 6px;
      font-size: 14px;
    }
    .primary-nav ul {
      gap: 0;
    }
    .primary-nav {
      gap: 4px;
    }
  }
  @media (max-width: 640px) {
    .brand-logo {
      height: 28px;
    }
  }

  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid rgb(var(--border));
    border-radius: 8px;
    color: rgb(var(--text-1));
    cursor: pointer;
    padding: 0;
  }
  .nav-toggle:hover {
    background: rgb(var(--surface-1));
  }
  .nav-toggle:focus-visible {
    outline: 2px solid rgb(var(--focus-ring));
    outline-offset: 2px;
  }
  .nav-toggle-bars {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    width: 18px;
  }
  .nav-toggle-bars span {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition:
      transform 180ms ease,
      opacity 120ms ease;
  }
  .primary-nav[data-open='true'] .nav-toggle-bars span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .primary-nav[data-open='true'] .nav-toggle-bars span:nth-child(2) {
    opacity: 0;
  }
  .primary-nav[data-open='true'] .nav-toggle-bars span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (max-width: 450px) {
    .nav-toggle {
      display: inline-flex;
    }
    .primary-nav {
      position: relative;
    }
    .primary-nav ul {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      flex-direction: column;
      gap: 4px;
      min-width: 180px;
      padding: 8px;
      background: rgb(var(--surface-1));
      border: 1px solid rgb(var(--border));
      border-radius: 12px;
      box-shadow: 0 12px 32px rgb(0 0 0 / 0.25);
      opacity: 0;
      transform: translateY(-6px);
      pointer-events: none;
      transition:
        opacity 160ms ease,
        transform 160ms ease;
    }
    .primary-nav[data-open='true'] ul {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
    .primary-nav ul li {
      width: 100%;
    }
    .primary-nav .nav-link {
      width: 100%;
      justify-content: flex-start;
      padding: 0 12px;
    }
    .primary-nav .nav-link.is-current::after {
      left: 12px;
      right: auto;
      width: 18px;
      bottom: 8px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .primary-nav ul,
    .nav-toggle-bars span {
      transition: none;
    }
  }
</style>

<script>
  function initNav() {
    const nav = document.querySelector<HTMLElement>('.primary-nav');
    const toggle = nav?.querySelector<HTMLButtonElement>('.nav-toggle');
    const menu = nav?.querySelector<HTMLUListElement>('#primary-menu');
    if (!nav || !toggle || !menu) return;

    function setOpen(open: boolean) {
      nav!.dataset.open = String(open);
      toggle!.setAttribute('aria-expanded', String(open));
      toggle!.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    }

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      setOpen(nav.dataset.open !== 'true');
    });

    menu.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) setOpen(false);
    });

    document.addEventListener('click', (e) => {
      if (nav.dataset.open === 'true' && !nav.contains(e.target as Node)) {
        setOpen(false);
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.dataset.open === 'true') setOpen(false);
    });
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
