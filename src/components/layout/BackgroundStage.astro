---
// BackgroundStage — soft ambient "Veil" plume backdrop.
// Locked config (from design handoff): veil vibe · 20% intensity · brand palette · non-reactive.
---

<div id="bg-stage" aria-hidden="true"></div>

<style is:global>
  html {
    background: rgb(var(--bg));
  }
  body {
    background: transparent;
  }
  #bg-stage {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
    background: rgb(var(--bg));
  }
  #bg-stage::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at 50% 45%,
      transparent 0%,
      transparent 45%,
      rgb(var(--bg) / 0.55) 100%
    );
  }
  #bg-stage canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    #bg-stage canvas {
      display: none;
    }
  }
</style>

<script>
  type Vec3 = [number, number, number];
  const BRAND: Vec3[] = [
    [0, 212, 255],
    [91, 79, 230],
    [9, 9, 121],
  ];
  const rgba = (c: Vec3, a: number) => `rgba(${c[0]},${c[1]},${c[2]},${a})`;

  const INTENSITY = 0.2;

  let raf = 0;
  let detachResize: (() => void) | null = null;
  let themeObserver: MutationObserver | null = null;

  function stopVeil() {
    if (raf) cancelAnimationFrame(raf);
    raf = 0;
    if (detachResize) {
      detachResize();
      detachResize = null;
    }
    const stage = document.getElementById('bg-stage');
    if (stage) stage.innerHTML = '';
  }

  function startVeil() {
    const stage = document.getElementById('bg-stage');
    if (!stage) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const canvas = document.createElement('canvas');
    stage.appendChild(canvas);
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const resize = () => {
      const r = stage.getBoundingClientRect();
      canvas.width = Math.max(1, Math.floor(r.width * dpr));
      canvas.height = Math.max(1, Math.floor(r.height * dpr));
    };
    resize();
    window.addEventListener('resize', resize);
    detachResize = () => window.removeEventListener('resize', resize);

    const isDark = () => document.documentElement.dataset.theme !== 'light';
    const baseA = 0.06 + INTENSITY * 0.28;

    let t0 = performance.now();
    let phase = 0;

    const frame = (t: number) => {
      const dt = t - t0;
      t0 = t;
      phase += 0.00012 * dt;

      const W = canvas.width;
      const H = canvas.height;
      const dark = isDark();

      ctx.globalCompositeOperation = 'source-over';
      ctx.fillStyle = dark ? 'rgba(12,14,20,0.3)' : 'rgba(247,245,239,0.3)';
      ctx.fillRect(0, 0, W, H);
      ctx.globalCompositeOperation = dark ? 'screen' : 'multiply';

      // Plume 1 — indigo, bottom-left
      {
        const cx = (0.1 + Math.sin(phase) * 0.08) * W;
        const cy = (0.95 + Math.cos(phase * 0.6) * 0.06) * H;
        const r = 1.0 * Math.max(W, H);
        const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
        g.addColorStop(0, rgba(BRAND[1], baseA));
        g.addColorStop(0.4, rgba(BRAND[1], baseA * 0.35));
        g.addColorStop(1, rgba(BRAND[1], 0));
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, W, H);
      }
      // Plume 2 — cyan, upper-right
      {
        const cx = (0.85 + Math.cos(phase * 0.9) * 0.06) * W;
        const cy = (0.1 + Math.sin(phase * 1.1) * 0.05) * H;
        const r = 0.7 * Math.max(W, H);
        const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
        g.addColorStop(0, rgba(BRAND[0], baseA * 0.7));
        g.addColorStop(0.5, rgba(BRAND[0], baseA * 0.15));
        g.addColorStop(1, rgba(BRAND[0], 0));
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, W, H);
      }

      ctx.globalCompositeOperation = 'source-over';
      raf = requestAnimationFrame(frame);
    };
    raf = requestAnimationFrame(frame);
  }

  function watchTheme() {
    themeObserver?.disconnect();
    themeObserver = new MutationObserver(() => {
      // The frame loop reads the theme each tick, so no restart needed;
      // observer is kept for potential future hooks.
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }

  function boot() {
    stopVeil();
    startVeil();
    watchTheme();
  }

  boot();
  document.addEventListener('astro:after-swap', boot);
  document.addEventListener('astro:before-swap', stopVeil);
</script>
