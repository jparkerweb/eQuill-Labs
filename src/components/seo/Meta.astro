---
interface Props {
  title: string;
  description: string;
  canonicalURL: URL;
  image?: URL;
  type?: 'website' | 'article';
}

const siteURL = Astro.site ?? new URL('https://www.equilllabs.com');
const {
  title,
  description,
  canonicalURL,
  image = new URL('/og/default.png', siteURL),
  type = 'website',
} = Astro.props;

const canonicalHref = canonicalURL.toString();
const imageHref = image.toString();
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalHref} />

<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:image" content={imageHref} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="eQuill Labs" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageHref} />
