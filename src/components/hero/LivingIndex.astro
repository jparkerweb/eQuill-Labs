---
import type { CollectionEntry } from 'astro:content';
import SlashGlyph from '@/components/brand/SlashGlyph.astro';
import logoSvgRaw from '/public/brand/logo-outline-half.svg?raw';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
const sorted = [...projects]
  .sort(
    (a, b) =>
      new Date(b.data.lastCommit ?? 0).getTime() - new Date(a.data.lastCommit ?? 0).getTime(),
  )
  .slice(0, 30);

const mobileTop = sorted.slice(0, 8);

// GitHub's official language colors (https://github.com/ozh/github-colors)
const LANGUAGE_COLORS: Record<string, string> = {
  JavaScript: '#f1e05a',
  TypeScript: '#3178c6',
  PowerShell: '#012456',
  Shell: '#89e051',
  Batchfile: '#C1F12E',
  CSS: '#663399',
  HTML: '#e34c26',
  Go: '#00ADD8',
  Python: '#3572A5',
  Rust: '#dea584',
  Ruby: '#701516',
  Java: '#b07219',
  C: '#555555',
  'C++': '#f34b7d',
  'C#': '#178600',
  Swift: '#F05138',
  Kotlin: '#A97BFF',
  Astro: '#ff5a03',
  Vue: '#41b883',
  Svelte: '#ff3e00',
};

function languageColor(lang: string | undefined): string {
  if (!lang) return '#8b949e';
  return LANGUAGE_COLORS[lang] ?? '#8b949e';
}
---

<section class="living-index" aria-label="Living index">
  <div class="copy">
    <h1 class="logo" aria-label="eQuill Labs" set:html={logoSvgRaw} />
    <p class="tagline">Building tools to enrich our digital lives</p>
    <p class="subtagline">
      Open-source AI engineering by Justin Parker
      <SlashGlyph role="separator" />
      updated continuously from GitHub
    </p>
    <div class="ctas">
      <a class="btn btn-primary" href="/projects/">Browse projects</a>
      <a class="btn btn-ghost" href="/about/">About Justin</a>
    </div>
  </div>

  <div class="feed" data-living-feed>
    <div class="marquee" data-marquee>
      <ul role="list" class="marquee-track">
        {
          [...sorted, ...sorted].map((p) => (
            <li class="mini-item">
              <a href={`/projects/${p.id}/`} class="mini-card">
                <span class="dot" style={`background: ${languageColor(p.data.primaryLanguage)};`} aria-hidden="true" />
                <div class="mini-body">
                  <span class="mini-name">{p.data.name}</span>
                  <p class="mini-meta">
                    {p.data.primaryLanguage && <span class="tag">{p.data.primaryLanguage}</span>}
                    {p.data.category && <span class="tag">{p.data.category}</span>}
                    {p.data.theme && <span class="tag">{p.data.theme}</span>}
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <ul role="list" class="static-list">
      {
        mobileTop.map((p) => (
          <li class="mini-item">
            <a href={`/projects/${p.id}/`} class="mini-card">
              <span class="dot" style={`background: ${languageColor(p.data.primaryLanguage)};`} aria-hidden="true" />
              <div class="mini-body">
                <span class="mini-name">{p.data.name}</span>
                <p class="mini-meta">
                  {p.data.primaryLanguage && <span class="tag">{p.data.primaryLanguage}</span>}
                  {p.data.category && <span class="tag">{p.data.category}</span>}
                  {p.data.theme && <span class="tag">{p.data.theme}</span>}
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .living-index {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
    gap: 48px;
    align-items: center;
    padding: 80px 24px 60px;
    max-width: 1280px;
    margin: 0 auto;
    min-height: 60svh;
  }
  @media (max-width: 960px) {
    .living-index {
      grid-template-columns: 1fr;
      padding: 48px 20px;
      gap: 32px;
    }
  }

  .copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .logo {
    margin: 0 0 20px;
    line-height: 0;
    display: block;
    width: min(100%, 340px);
  }
  .logo :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
  .subtagline {
    justify-content: center;
  }
  .tagline {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: clamp(22px, 3vw, 28px);
    color: rgb(var(--text-1));
    margin: 0 0 12px;
    line-height: 1.2;
  }
  .subtagline {
    color: rgb(var(--text-muted));
    font-size: 14px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin: 0 0 24px;
  }
  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 0 20px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
    transition:
      background 150ms ease,
      border-color 150ms ease,
      color 150ms ease;
  }
  .btn-primary {
    background: rgb(var(--accent));
    color: rgb(var(--accent-contrast));
    border: 1px solid rgb(var(--accent));
  }
  .btn-primary:hover {
    filter: brightness(1.08);
  }
  .btn-ghost {
    background: transparent;
    color: rgb(var(--text-1));
    border: 1px solid rgb(var(--border));
  }
  .btn-ghost:hover {
    border-color: rgb(var(--accent));
  }
  .btn:focus-visible {
    outline: 2px solid rgb(var(--focus-ring));
    outline-offset: 2px;
  }

  .feed {
    position: relative;
    height: 480px;
    overflow: hidden;
    border: 1px solid rgb(var(--border));
    border-radius: 16px;
    background: rgb(var(--surface-1) / 0.5);
    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      180deg,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
  }

  .marquee {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .marquee-track {
    list-style: none;
    padding: 16px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    animation: scroll-y 120s linear infinite;
  }

  .marquee[data-paused='true'] .marquee-track {
    animation-play-state: paused;
  }

  @keyframes scroll-y {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%);
    }
  }

  .static-list {
    display: none;
    list-style: none;
    padding: 16px;
    margin: 0;
    gap: 10px;
    flex-direction: column;
  }

  .mini-item {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .mini-card {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    background: rgb(var(--surface-2));
    border: 1px solid rgb(var(--border));
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition:
      transform 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease;
  }
  .mini-card::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 2px;
    border-radius: inherit;
    background: conic-gradient(
      from var(--mini-gradient-angle),
      rgb(var(--grad-1)),
      rgb(var(--grad-2)),
      rgb(var(--grad-3)),
      rgb(var(--grad-2)),
      rgb(var(--grad-1))
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 200ms ease;
    pointer-events: none;
  }
  .mini-card:hover,
  .mini-card:focus-visible {
    transform: translateY(-2px);
    border-color: transparent;
    box-shadow: 0 12px 30px -18px rgb(var(--accent) / 0.6);
  }
  .mini-card:hover::before,
  .mini-card:focus-visible::before {
    opacity: 1;
    animation: mini-card-trace 4s linear infinite;
  }
  .mini-card:focus-visible {
    outline: 2px solid rgb(var(--focus-ring));
    outline-offset: 2px;
  }
  @keyframes mini-card-trace {
    to {
      --mini-gradient-angle: 360deg;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .mini-card:hover::before,
    .mini-card:focus-visible::before {
      animation: none;
    }
    .mini-card:hover,
    .mini-card:focus-visible {
      border-color: rgb(var(--accent));
    }
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    margin-top: 6px;
    flex: none;
  }
  .mini-body {
    min-width: 0;
    flex: 1;
  }
  .mini-name {
    font-size: 14px;
    font-weight: 500;
    color: rgb(var(--text-1));
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .mini-meta {
    margin: 4px 0 0;
    font-size: 11px;
    color: rgb(var(--text-muted));
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-items: center;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    padding: 2px 7px;
    border-radius: 999px;
    background: rgb(var(--surface-1));
    border: 1px solid rgb(var(--border));
    color: rgb(var(--text-2));
    font-size: 10px;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .feed {
      height: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }
    .marquee {
      display: none;
    }
    .static-list {
      display: flex;
      position: relative;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee {
      display: none;
    }
    .static-list {
      display: flex;
      position: relative;
    }
    .feed {
      height: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>

<script>
  function init() {
    const marquees = document.querySelectorAll<HTMLElement>('[data-marquee]');
    marquees.forEach((m) => {
      m.addEventListener('mouseenter', () => (m.dataset.paused = 'true'));
      m.addEventListener('mouseleave', () => (m.dataset.paused = 'false'));
      m.addEventListener('focusin', () => (m.dataset.paused = 'true'));
      m.addEventListener('focusout', () => (m.dataset.paused = 'false'));
    });
  }

  document.addEventListener('astro:page-load', init);
</script>
