---
import type { HTMLAttributes } from 'astro/types';

type Props = {
  animate?: boolean;
  role?: HTMLAttributes<'span'>['role'];
  class?: string;
};

const { animate = false, role, class: className = '' } = Astro.props;
---

<span
  class:list={['slash-glyph', className, { 'slash-animate': animate }]}
  role={role}
  aria-hidden={role ? undefined : 'true'}>\\</span>

<style>
  .slash-glyph {
    font-family:
      'Geist Mono Variable',
      ui-monospace,
      SFMono-Regular,
      Menlo,
      monospace;
    font-weight: 700;
    letter-spacing: -0.04em;
    background-image: linear-gradient(
      90deg,
      rgb(var(--grad-1)) 0%,
      rgb(var(--grad-2)) 50%,
      rgb(var(--grad-3)) 100%
    );
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }

  .slash-animate {
    animation: quill-stroke 700ms ease-out both;
  }

  @keyframes quill-stroke {
    from {
      opacity: 0;
      transform: translateY(-0.2em) rotate(-6deg);
      filter: blur(2px);
    }
    to {
      opacity: 1;
      transform: none;
      filter: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .slash-animate {
      animation: none;
    }
  }
</style>
