---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import JsonLd from '@/components/seo/JsonLd.astro';

const entry = await getEntry('pages', 'about');
if (!entry) {
  throw new Error('Missing content: pages/about');
}
const { Content } = await entry.render();

const siteURL = Astro.site ?? new URL('https://www.equilllabs.com');
---

<BaseLayout title={entry.data.title} description={entry.data.description} image="/og/about.png">
  <JsonLd
    type="Person"
    data={{
      name: 'Justin Parker',
      alternateName: 'jparkerweb',
      url: new URL('/about/', siteURL).toString(),
      jobTitle: 'AI Engineer',
      description:
        'Building tools to enrich our digital lives. Focus areas include LLM infrastructure, semantic NLP, MCP tooling, and the Obsidian ecosystem.',
      sameAs: [
        'https://github.com/jparkerweb',
        'https://www.linkedin.com/in/jparkerweb/',
        'https://x.com/jparkerweb',
      ],
      worksFor: { '@type': 'Organization', name: 'eQuill Labs' },
    }}
  />
  <JsonLd
    type="BreadcrumbList"
    data={{
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: siteURL.toString() },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'About',
          item: new URL('/about/', siteURL).toString(),
        },
      ],
    }}
  />
  <article class="prose">
    <Content />
  </article>
</BaseLayout>

<style>
  .prose {
    max-width: 65ch;
    margin: 40px auto 80px;
    padding: 0 24px;
    color: rgb(var(--text-1));
    line-height: 1.7;
  }
  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3) {
    font-family:
      'Geist Variable',
      ui-sans-serif,
      system-ui,
      sans-serif;
    letter-spacing: -0.01em;
    color: rgb(var(--text-1));
  }
  .prose :global(h1) {
    font-size: clamp(32px, 4vw, 44px);
    margin: 0 0 24px;
  }
  .prose :global(h2) {
    font-size: clamp(22px, 2.5vw, 28px);
    margin-top: 2em;
    margin-bottom: 0.5em;
  }
  .prose :global(h3) {
    font-size: 18px;
    margin-top: 1.75em;
    margin-bottom: 0.5em;
  }
  .prose :global(p) {
    color: rgb(var(--text-2));
    margin: 0 0 1em;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4em;
    color: rgb(var(--text-2));
  }
  .prose :global(li) {
    margin: 0.35em 0;
  }
  .prose :global(a) {
    color: rgb(var(--text-1));
    text-decoration: none;
    background-image: linear-gradient(
      90deg,
      rgb(var(--grad-1)),
      rgb(var(--grad-2)),
      rgb(var(--grad-3))
    );
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 100% 2px;
    padding-bottom: 2px;
  }
  .prose :global(strong) {
    color: rgb(var(--text-1));
  }
</style>
