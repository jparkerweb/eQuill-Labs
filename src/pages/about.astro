---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import SlashGlyph from '@/components/brand/SlashGlyph.astro';
import { Github, Mail, Globe, BrainCircuit, Layers, Plug, BookOpen, Heart } from 'lucide-astro';

const entry = await getEntry('pages', 'about');
if (!entry) {
  throw new Error('Missing content: pages/about');
}

const siteURL = Astro.site ?? new URL('https://www.equilllabs.com');

const focusAreas = [
  {
    icon: 'brain',
    title: 'LLM Infrastructure',
    desc: 'Semantic chunking, embedding pipelines, Bedrock proxies, and the small, boring glue code that makes larger systems work.',
  },
  {
    icon: 'layers',
    title: 'Semantic NLP',
    desc: 'Topic extraction, chunk matching, and embedding utilities designed to be composable building blocks, not monoliths.',
  },
  {
    icon: 'plug',
    title: 'MCP Tooling',
    desc: 'Servers and clients for the Model Context Protocol ecosystem, with an emphasis on SQLite, filesystem, and agent-friendly primitives.',
  },
  {
    icon: 'book',
    title: 'Obsidian Ecosystem',
    desc: 'Plugins that treat Obsidian as a serious authoring surface: banners, footers, spellchecking, embedding search, and more.',
  },
];

const timeline = [
  { year: '2019', text: 'First open-source releases under the jparkerweb banner' },
  { year: '2022', text: 'Began focused work on experimentation tooling and LLM infrastructure' },
  { year: '2024', text: 'Shipped semantic-chunking; the Obsidian plugin family hits its stride' },
  { year: '2025', text: 'MCP tooling wave: mcp-sqlite, mcp-filesystem, and friends' },
  { year: '2026', text: 'eQuill Labs v2: a ground-up redesign built to keep up with the output' },
];

const links = [
  { icon: 'github', label: 'GitHub', href: 'https://github.com/jparkerweb', sub: 'github.com/jparkerweb' },
  { icon: 'globe', label: 'eQuill Labs', href: 'https://www.equilllabs.com', sub: 'equilllabs.com' },
  { icon: 'mail', label: 'Email', href: 'mailto:hello@equilllabs.com', sub: 'hello@equilllabs.com' },
];
---

<BaseLayout title={entry.data.title} description={entry.data.description} image="/og/about.png">
  <JsonLd
    type="Person"
    data={{
      name: 'Justin Parker',
      alternateName: 'jparkerweb',
      url: new URL('/about/', siteURL).toString(),
      jobTitle: 'AI Engineer',
      description:
        'Building tools to enrich our digital lives. Focus areas include LLM infrastructure, semantic NLP, MCP tooling, and the Obsidian ecosystem.',
      sameAs: [
        'https://github.com/jparkerweb',
        'https://www.linkedin.com/in/jparkerweb/',
        'https://x.com/jparkerweb',
      ],
      worksFor: { '@type': 'Organization', name: 'eQuill Labs' },
    }}
  />
  <JsonLd
    type="BreadcrumbList"
    data={{
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: siteURL.toString() },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'About',
          item: new URL('/about/', siteURL).toString(),
        },
      ],
    }}
  />

  <!-- ─── HERO ─── -->
  <section class="hero" aria-label="Introduction">
    <div class="shell">
      <div class="hero-content" data-reveal>
        <p class="hero-eyebrow">About</p>
        <h1 class="hero-name">
          Justin Parker
          <SlashGlyph animate />
        </h1>
        <p class="hero-role">AI Engineer & Open-Source Builder</p>
        <p class="hero-tagline">Building tools to enrich our digital lives.</p>
      </div>
    </div>
  </section>

  <!-- ─── WHO ─── -->
  <section class="who-section" aria-labelledby="who-heading">
    <div class="shell">
      <div class="who-grid" data-reveal>
        <div class="who-label">
          <h2 id="who-heading">
            Who <SlashGlyph />
          </h2>
        </div>
        <div class="who-body">
          <p>
            I'm an engineer who has spent the last decade shipping software at the intersection of
            experimentation, user experience, and machine learning. Long before LLMs were a
            household term, I was wiring up statistical pipelines, running large-scale
            experimentation platforms, and building internal tools for teams that needed answers
            faster than dashboards could provide them.
          </p>
          <p>
            <strong>eQuill Labs</strong> is the umbrella for the public side of that work — the corner
            of the internet where the tools, experiments, and half-formed ideas that I'd otherwise
            keep in a private notes folder get polished, documented, and shipped as open source.
          </p>
          <p>
            I write code because I like making things that get used. Some of what's here started as a
            problem I hit once and wanted to solve properly; some started as a demo that grew teeth;
            some started because a tool I needed simply didn't exist yet.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FOCUS AREAS ─── -->
  <section class="focus-section" aria-labelledby="focus-heading">
    <div class="shell">
      <header class="section-header" data-reveal>
        <h2 id="focus-heading">
          What I Build <SlashGlyph />
        </h2>
        <p class="section-sub">Small, composable tools that solve one problem well and compose cleanly with whatever comes next.</p>
      </header>
      <div class="focus-grid">
        {focusAreas.map((area, i) => (
          <div class="focus-card" data-reveal style={`--delay: ${i * 80}ms`}>
            <div class="focus-icon" aria-hidden="true">
              {area.icon === 'brain' && <BrainCircuit size={22} />}
              {area.icon === 'layers' && <Layers size={22} />}
              {area.icon === 'plug' && <Plug size={22} />}
              {area.icon === 'book' && <BookOpen size={22} />}
            </div>
            <h3>{area.title}</h3>
            <p>{area.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── FAMILY & FAITH ─── -->
  <section class="faith-section" aria-labelledby="faith-heading">
    <div class="shell">
      <div class="faith-card" data-reveal>
        <div class="faith-icon" aria-hidden="true">
          <Heart size={20} />
        </div>
        <h2 id="faith-heading">Family & Faith</h2>
        <p>
          Outside the terminal, I'm a husband to <strong>Stephanie</strong> and a dad to
          <strong>Ella</strong> and <strong>Lily</strong>. My family is the anchor behind every
          late-night push and weekend release.
        </p>
        <p>
          My Christian faith shapes how I try to work — with honesty, care for the people using
          what I ship, and a bias toward building things that serve rather than extract. It's not
          the loudest part of this site, but it's the part that makes the rest of it worth doing.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── TIMELINE ─── -->
  <section class="timeline-section" aria-labelledby="timeline-heading">
    <div class="shell">
      <header class="section-header" data-reveal>
        <h2 id="timeline-heading">
          Timeline <SlashGlyph />
        </h2>
      </header>
      <ol class="timeline" role="list">
        {timeline.map((item, i) => (
          <li class="timeline-item" data-reveal style={`--delay: ${i * 100}ms`}>
            <span class="timeline-dot" aria-hidden="true" />
            <span class="timeline-year">{item.year}</span>
            <span class="timeline-text">{item.text}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ─── FIND ME ─── -->
  <section class="links-section" aria-labelledby="links-heading">
    <div class="shell">
      <header class="section-header" data-reveal>
        <h2 id="links-heading">
          Find Me <SlashGlyph />
        </h2>
      </header>
      <div class="links-grid">
        {links.map((link, i) => (
          <a class="link-card" href={link.href} target={link.href.startsWith('mailto') ? undefined : '_blank'} rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'} data-reveal style={`--delay: ${i * 80}ms`}>
            <span class="link-icon" aria-hidden="true">
              {link.icon === 'github' && <Github size={20} />}
              {link.icon === 'globe' && <Globe size={20} />}
              {link.icon === 'mail' && <Mail size={20} />}
            </span>
            <span class="link-label">{link.label}</span>
            <span class="link-sub">{link.sub}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Shell ── */
  .shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── HERO ── */
  .hero {
    padding: 72px 0 56px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -60%;
    right: -20%;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgb(var(--accent) / 0.06) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .hero-content {
    max-width: 700px;
  }
  .hero-eyebrow {
    font-family: 'Geist Mono Variable', ui-monospace, SFMono-Regular, monospace;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgb(var(--accent));
    margin: 0 0 16px;
    font-weight: 500;
  }
  .hero-name {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 12px;
    color: rgb(var(--text-1));
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hero-role {
    font-size: clamp(16px, 2vw, 20px);
    color: rgb(var(--text-2));
    margin: 0 0 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .hero-tagline {
    font-family: 'Instrument Serif', Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: clamp(20px, 3vw, 28px);
    color: rgb(var(--text-1));
    line-height: 1.35;
    margin: 0;
  }

  /* ── WHO ── */
  .who-section {
    padding: 48px 0;
  }
  .who-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 40px;
    align-items: start;
  }
  .who-label h2 {
    font-size: clamp(24px, 3vw, 32px);
    letter-spacing: -0.02em;
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    position: sticky;
    top: 80px;
  }
  .who-body {
    max-width: 65ch;
  }
  .who-body p {
    color: rgb(var(--text-2));
    line-height: 1.7;
    margin: 0 0 1em;
    font-size: 16px;
  }
  .who-body p:last-child {
    margin-bottom: 0;
  }
  .who-body strong {
    color: rgb(var(--text-1));
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .who-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .who-label h2 {
      position: static;
    }
  }

  /* ── SECTION HEADERS ── */
  .section-header {
    margin-bottom: 32px;
  }
  .section-header h2 {
    font-size: clamp(24px, 3vw, 32px);
    letter-spacing: -0.02em;
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }
  .section-sub {
    font-family: 'Instrument Serif', Georgia, 'Times New Roman', serif;
    font-style: italic;
    color: rgb(var(--text-muted));
    margin: 8px 0 0;
    font-size: clamp(15px, 2vw, 17px);
    max-width: 55ch;
    line-height: 1.5;
  }

  /* ── FOCUS AREAS ── */
  .focus-section {
    padding: 48px 0;
  }
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .focus-card {
    background: rgb(var(--surface-1));
    border: 1px solid rgb(var(--border));
    border-radius: 14px;
    padding: 24px;
    transition: border-color 200ms ease, transform 200ms ease;
    animation-delay: var(--delay, 0ms);
  }
  .focus-card:hover {
    border-color: rgb(var(--accent) / 0.4);
    transform: translateY(-2px);
  }
  .focus-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgb(var(--accent) / 0.1);
    color: rgb(var(--accent));
    margin-bottom: 16px;
  }
  .focus-card h3 {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
    color: rgb(var(--text-1));
  }
  .focus-card p {
    font-size: 14px;
    line-height: 1.6;
    color: rgb(var(--text-muted));
    margin: 0;
  }

  @media (max-width: 640px) {
    .focus-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── FAMILY & FAITH ── */
  .faith-section {
    padding: 48px 0;
  }
  .faith-card {
    background: rgb(var(--surface-1));
    border: 1px solid rgb(var(--border));
    border-radius: 14px;
    padding: 32px;
    max-width: 680px;
    position: relative;
  }
  .faith-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgb(var(--accent) / 0.1);
    color: rgb(var(--accent));
    margin-bottom: 16px;
  }
  .faith-card h2 {
    font-size: 22px;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
    color: rgb(var(--text-1));
  }
  .faith-card p {
    color: rgb(var(--text-2));
    line-height: 1.7;
    margin: 0 0 1em;
    font-size: 15px;
  }
  .faith-card p:last-child {
    margin-bottom: 0;
  }
  .faith-card strong {
    color: rgb(var(--text-1));
    font-weight: 600;
  }

  /* ── TIMELINE ── */
  .timeline-section {
    padding: 48px 0;
  }
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(
      180deg,
      rgb(var(--grad-1)),
      rgb(var(--grad-2)),
      rgb(var(--grad-3))
    );
    border-radius: 1px;
  }
  .timeline-item {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: baseline;
    gap: 16px;
    padding: 12px 0;
    position: relative;
    animation-delay: var(--delay, 0ms);
  }
  .timeline-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid rgb(var(--accent));
    background: rgb(var(--bg));
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    transition: background 200ms ease, box-shadow 200ms ease;
  }
  .timeline-item:hover .timeline-dot {
    background: rgb(var(--accent));
    box-shadow: 0 0 12px rgb(var(--accent) / 0.4);
  }
  .timeline-year {
    font-family: 'Geist Mono Variable', ui-monospace, SFMono-Regular, monospace;
    font-size: 14px;
    font-weight: 600;
    color: rgb(var(--accent));
    min-width: 48px;
  }
  .timeline-text {
    font-size: 15px;
    color: rgb(var(--text-2));
    line-height: 1.5;
  }

  /* ── FIND ME ── */
  .links-section {
    padding: 48px 0 80px;
  }
  .links-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .link-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    background: rgb(var(--surface-1));
    border: 1px solid rgb(var(--border));
    border-radius: 14px;
    padding: 20px 24px;
    text-decoration: none;
    transition: border-color 200ms ease, transform 200ms ease;
    animation-delay: var(--delay, 0ms);
  }
  .link-card:hover {
    border-color: rgb(var(--accent) / 0.4);
    transform: translateY(-2px);
  }
  .link-icon {
    color: rgb(var(--accent));
    margin-bottom: 8px;
  }
  .link-label {
    font-size: 16px;
    font-weight: 600;
    color: rgb(var(--text-1));
    letter-spacing: -0.01em;
  }
  .link-sub {
    font-size: 13px;
    color: rgb(var(--text-muted));
    font-family: 'Geist Mono Variable', ui-monospace, SFMono-Regular, monospace;
  }

  @media (max-width: 640px) {
    .links-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── REDUCED MOTION ── */
  @media (prefers-reduced-motion: reduce) {
    .focus-card,
    .timeline-item,
    .link-card {
      animation-delay: 0ms !important;
    }
    .focus-card:hover,
    .link-card:hover {
      transform: none;
    }
  }
</style>
