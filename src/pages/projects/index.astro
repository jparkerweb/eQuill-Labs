---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectFilters from '@/components/projects/ProjectFilters.astro';
import ProjectGrid from '@/components/projects/ProjectGrid.astro';
import JsonLd from '@/components/seo/JsonLd.astro';

const siteURL = Astro.site ?? new URL('https://www.equilllabs.com');

const all = await getCollection('projects');
const visible = all
  .filter((e) => e.data.status !== 'hidden')
  .sort((a, b) => {
    const fa = a.data.featured ? 0 : 1;
    const fb = b.data.featured ? 0 : 1;
    if (fa !== fb) return fa - fb;
    const sa = a.data.sortOrder ?? 100;
    const sb = b.data.sortOrder ?? 100;
    if (sa !== sb) return sa - sb;
    return b.data.stars - a.data.stars;
  });

const featuredCount = visible.filter((e) => e.data.featured).length;
---

<BaseLayout
  title="Projects — eQuill Labs"
  description="All open-source projects by Justin Parker."
  image="/og/projects.png">
  <JsonLd
    type="BreadcrumbList"
    data={{
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: siteURL.toString() },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Projects',
          item: new URL('/projects/', siteURL).toString(),
        },
      ],
    }}
  />
  <section class="catalog">
    <div class="shell">
      <header class="head">
        <h1>Projects</h1>
        <p class="count">{visible.length} projects, {featuredCount} featured</p>
      </header>

      <ProjectFilters projects={visible} gridSelector="#project-grid" />

      <div id="project-grid">
        <ProjectGrid projects={visible} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .catalog {
    padding: 40px 0 80px;
  }
  .shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .head {
    margin-bottom: 24px;
  }
  h1 {
    font-size: clamp(32px, 5vw, 48px);
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }
  .count {
    margin: 0;
    color: rgb(var(--text-muted));
    font-size: 14px;
  }
</style>
