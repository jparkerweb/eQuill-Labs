---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SlashGlyph from '@/components/brand/SlashGlyph.astro';
---

<BaseLayout title="Page not found — eQuill Labs" description="The page you requested doesn't exist.">
  <section class="nf">
    <div class="big">
      <SlashGlyph />
    </div>
    <h1>Page not found</h1>
    <p>
      The page you requested doesn't exist. Try the
      <a href="/projects/">projects catalog</a> or <a href="/">home</a>.
    </p>
  </section>
</BaseLayout>

<style>
  .nf {
    max-width: 640px;
    margin: 0 auto;
    padding: 80px 24px 120px;
    text-align: center;
  }
  .big {
    font-size: 160px;
    line-height: 1;
    margin-bottom: 16px;
  }
  h1 {
    font-size: clamp(28px, 4vw, 40px);
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }
  p {
    color: rgb(var(--text-2));
    font-size: 16px;
    line-height: 1.6;
  }
  a {
    color: rgb(var(--text-1));
    text-decoration: none;
    background-image: linear-gradient(
      90deg,
      rgb(var(--grad-1)),
      rgb(var(--grad-2)),
      rgb(var(--grad-3))
    );
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 100% 2px;
    padding-bottom: 2px;
  }
</style>
